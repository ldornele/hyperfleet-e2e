{
  "kind": "Cluster",
  "name": "hp-cluster-small-{{.Random}}",
  "labels": {
    "environment": "test",
    "shard": "1"
  },
  "spec": {
    "platform": {
      "type": "gcp",
      "gcp": {
        "projectID": "my-gcp-project",
        "region": "us-central1"
      }
    },
    "release": {
      "version": "4.14.0"
    },
    "networking": {
      "clusterNetwork": [
        {
          "cidr": "10.10.0.0/16",
          "hostPrefix": 24
        }
      ],
      "serviceNetwork": ["10.96.0.0/12"]
    },
    "dns": {
      "baseDomain": "example.com"
    }
  }
}
